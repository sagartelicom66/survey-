rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only authenticated admins can read all responses, winners, settings
    match /responses/{id} {
      allow create: if true; // public can submit
      allow read, update, delete: if request.auth != null;
    }

    match /winners/{id} {
      allow read, write: if request.auth != null;
    }

    match /settings/{id} {
      allow read: if true; // public needs to check survey status
      allow write: if request.auth != null;
    }

    match /admins/{id} {
      allow read, write: if request.auth != null && request.auth.uid == id;
    }
  }
}
